{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/cabo-shuttle run build",
  "outputDirectory": "artifacts/cabo-shuttle/dist/public",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
